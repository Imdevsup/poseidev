{
  "name": "poseidev",
  "version": "1.0.0",
  "description": "Poseidev — The AI-Powered CLI Code Editor. Multi-model orchestration, auto-build, agent collaboration, and more.",
  "homepage": "https://github.com/Imdevsup/poseidev#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Imdevsup/poseidev.git"
  },
  "bugs": {
    "url": "https://github.com/Imdevsup/poseidev/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "poseidev": "dist/index.js",
    "psd": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --target node18 --minify",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "code-editor",
    "code-generation",
    "nvidia",
    "multi-model",
    "agent",
    "autobuild",
    "poseidev"
  ],
  "author": "Poseidev",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "boxen": "^8.0.1",
    "ora": "^8.2.0",
    "inquirer": "^12.3.2",
    "cli-table3": "^0.6.5",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "cli-highlight": "^2.1.11",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "openai": "^4.77.0",
    "glob": "^11.0.1",
    "chokidar": "^4.0.3",
    "diff": "^7.0.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "cli-spinners": "^3.3.0",
    "log-update": "^6.1.0",
    "terminal-link": "^3.0.0",
    "cli-progress": "^3.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/diff": "^6.0.0",
    "@types/inquirer": "^9.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
